rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is signed in
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Helper function to check if the user is accessing their own document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Rules for User documents (root-level /users/{userId})
    match /users/{userId} {
      // Allow the user to read/write their own root document
      allow read, write: if isSignedIn() && isOwner(userId);
      
      // Since all other app data (Invoices, Parties, Payments) is stored 
      // as subcollections under the user's specific document (users/{userId}/*),
      // we can apply a secure blanket rule for any documents within these subcollections
      match /{document=**} {
        allow read, write: if isSignedIn() && isOwner(userId);
      }
    }

    // Deny access to all other paths outside the users collection
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
